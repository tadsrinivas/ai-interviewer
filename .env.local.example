# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Tavus (for AI avatar)
TAVUS_API_KEY=xxxxx
TAVUS_REPLICA_ID=xxxxx
TAVUS_PERSONA_ID=xxxxx

# AWS S3 for Tavus to WRITE recordings (federated identity)
RECORDING_S3_BUCKET=talentgauge-recordings
RECORDING_S3_REGION=us-east-1
RECORDING_S3_ROLE_ARN=arn:aws:iam::123456789012:role/TavusRecordingWriter

# AWS S3 for app to READ recordings (separate IAM user with read-only access)
AWS_S3_BUCKET=talentgauge-recordings
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxx
AWS_SECRET_ACCESS_KEY=xxxxx

# Resend (for emails)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=interviews@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
